{
  "title": "Cash Flow — Visão Geral",
  "uid": "cashflow-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Entry Service",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Lançamentos criados / min",
      "description": "Taxa de lançamentos criados particionada por tipo (CREDITO / DEBITO)",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (tipo) (rate(lancamentos_criados_total[1m])) * 60",
          "legendFormat": "{{ tipo }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latência HTTP P95 — POST /lancamentos (ms)",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{route=\"/lancamentos\",method=\"POST\"}[5m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{route=\"/lancamentos\",method=\"POST\"}[5m])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox — Eventos publicados vs Falhas / min",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(outbox_eventos_publicados_total[1m]) * 60",
          "legendFormat": "Publicados",
          "refId": "A"
        },
        {
          "expr": "rate(outbox_eventos_falhas_total[1m]) * 60",
          "legendFormat": "Falhas",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Consolidated Service",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Eventos processados / min",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (tipo) (rate(consolidated_lancamentos_processados_total[1m])) * 60",
          "legendFormat": "Processados ({{ tipo }})",
          "refId": "A"
        },
        {
          "expr": "rate(consolidated_lancamentos_duplicados_total[1m]) * 60",
          "legendFormat": "Duplicados (ignorados)",
          "refId": "B"
        },
        {
          "expr": "rate(consolidated_lancamentos_falhas_total[1m]) * 60",
          "legendFormat": "Falhas",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis — Cache Hit Rate (%)",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * rate(consolidated_redis_cache_hits_total[5m]) / (rate(consolidated_redis_cache_hits_total[5m]) + rate(consolidated_redis_cache_misses_total[5m]) + 0.001)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latência GET /consolidado/:data (ms)",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(consolidated_consolidado_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(consolidated_consolidado_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Infraestrutura (Node.js)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Heap utilizado — Consolidated Service (MB)",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "consolidated_nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "consolidated_nodejs_heap_size_total_bytes / 1024 / 1024",
          "legendFormat": "Heap Total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Event Loop Lag — Consolidated Service (ms)",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "consolidated_nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Event Loop Lag",
          "refId": "A"
        }
      ]
    }
  ]
}
